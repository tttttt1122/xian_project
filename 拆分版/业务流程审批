                                <td>综合管理</td>
                                <td>2024-01-12 11:20:00</td>
                                <td>审批流程不完整</td>
                                <td class="actions">
                                    <button class="btn btn-sm btn-primary" onclick="viewFlow()">查看</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="pagination">
                    <button class="page-btn" disabled>上一页</button>
                    <button class="page-btn active">1</button>
                    <button class="page-btn" disabled>下一页</button>
                </div>
            </div>
        </div>
    <!-- </main> -->

    <!-- 查看流程弹窗 -->
    <div id="viewFlowModal" class="modal">
        <div class="modal-content modal-large">
            <div class="modal-header">
                <span class="modal-title">流程详情</span>
                <button class="modal-close" onclick="closeModal('viewFlowModal')">×</button>
            </div>
            <div class="modal-body">
                <div class="view-section">
                    <h3 style="margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid #e8e8e8; color: #1890ff;">第一步：基本信息</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                        <div class="form-group">
                            <label>流程名称</label>
                            <input type="text" value="检查检验结果互认流程" readonly>
                        </div>
                        <div class="form-group">
                            <label>流程编码</label>
                            <input type="text" value="MED-001" readonly>
                        </div>
                        <div class="form-group">
                            <label>归属应用</label>
                            <input type="text" value="卫生健康智慧大脑" readonly>
                        </div>
                        <div class="form-group">
                            <label>发布应用</label>
                            <input type="text" value="全民健康信息平台" readonly>
                        </div>
                        <div class="form-group">
                            <label>业务域</label>
                            <input type="text" value="医疗服务" readonly>
                        </div>
                        <div class="form-group">
                            <label>发布状态</label>
                            <input type="text" value="待审批" readonly>
                        </div>
                    </div>
                    <div class="form-group" style="margin-top: 16px;">
                        <label>流程描述</label>
                        <textarea readonly style="min-height: 80px;">跨医疗机构检查检验结果互认审批流程，实现检验报告共享</textarea>
                    </div>
                </div>
                
                <div class="view-section">
                    <h3 style="margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid #e8e8e8; color: #1890ff;">第二步：流程建模</h3>
                    <div class="flow-viewer">
                        <div style="display: flex; align-items: center; justify-content: center; gap: 20px; flex-wrap: wrap;">
                            <div style="text-align: center;">
                                <div style="width: 80px; height: 40px; background: #52c41a; color: #fff; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 12px;">开始节点</div>
                            </div>
                            <div style="color: #999;">→</div>
                            <div style="text-align: center;">
                                <div style="width: 100px; height: 60px; background: #1890ff; color: #fff; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 12px;">待办任务<br>申请提交</div>
                            </div>
                            <div style="color: #999;">→</div>
                            <div style="text-align: center;">
                                <div style="width: 100px; height: 60px; background: #faad14; color: #fff; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 12px;">判断节点<br>资质审核</div>
                            </div>
                            <div style="color: #999;">→</div>
                            <div style="text-align: center;">
                                <div style="width: 100px; height: 60px; background: #1890ff; color: #fff; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 12px;">业务服务<br>结果互认</div>
                            </div>
                            <div style="color: #999;">→</div>
                            <div style="text-align: center;">
                                <div style="width: 80px; height: 40px; background: #ff4d4f; color: #fff; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 12px;">结束节点</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" onclick="closeModal('viewFlowModal')">关闭</button>
            </div>
        </div>
    </div>

    <!-- 审批通过确认弹窗 -->
    <div id="approveConfirmModal" class="modal">
        <div class="modal-content" style="width: 400px;">
            <div class="modal-header">
                <span class="modal-title">确认通过</span>
                <button class="modal-close" onclick="closeModal('approveConfirmModal')">×</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="approveFlowCode">
                <p style="margin-bottom: 16px;">确认通过该流程的审批？</p>
                <div style="padding: 12px; background: #f5f5f5; border-radius: 4px;">
                    <div><strong>流程编码：</strong><span id="approveCodeText"></span></div>
                    <div><strong>流程名称：</strong><span id="approveNameText"></span></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" onclick="closeModal('approveConfirmModal')">取消</button>
                <button class="btn btn-success" onclick="confirmApprove()">确认通过</button>
            </div>
        </div>
    </div>

    <!-- 拒绝原因弹窗 -->
    <div id="rejectModal" class="modal">
        <div class="modal-content" style="width: 500px;">
            <div class="modal-header">
                <span class="modal-title">拒绝审批</span>
                <button class="modal-close" onclick="closeModal('rejectModal')">×</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="rejectFlowCode">
                <div style="padding: 12px; background: #f5f5f5; border-radius: 4px; margin-bottom: 16px;">
                    <div><strong>流程编码：</strong><span id="rejectCodeText"></span></div>
                    <div><strong>流程名称：</strong><span id="rejectNameText"></span></div>
                </div>
                <div class="form-group">
                    <label>拒绝原因 <span style="color: #ff4d4f;">*</span></label>
                    <textarea id="rejectReason" placeholder="请输入拒绝原因" rows="4"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-default" onclick="closeModal('rejectModal')">取消</button>
                <button class="btn btn-danger" onclick="confirmReject()">确认拒绝</button>
            </div>
        </div>
    </div>

    <script>
        function switchApprovalTab(tab) {
            document.querySelectorAll('.approval-tab-panel').forEach(panel => {
                panel.classList.add('hidden');
            });
            document.querySelectorAll('.tab-item').forEach(item => {
                item.classList.remove('active');
            });
            event.target.classList.add('active');
            document.getElementById('approval-tab-' + tab).classList.remove('hidden');
        }

        function searchApprovalPending() {
            alert('查询待审批功能演示');
        }

        function resetApprovalPending() {
            document.getElementById('approval-pending-domain').value = '';
            document.getElementById('approval-pending-app').value = '';
            document.getElementById('approval-pending-pub').value = '';
            document.getElementById('approval-pending-name').value = '';
        }

        function searchApprovalPassed() {
            alert('查询已通过功能演示');
        }

        function resetApprovalPassed() {
            document.getElementById('approval-passed-domain').value = '';
            document.getElementById('approval-passed-name').value = '';
        }

        function searchApprovalRejected() {
            alert('查询已拒绝功能演示');
        }

        function resetApprovalRejected() {
            document.getElementById('approval-rejected-domain').value = '';
            document.getElementById('approval-rejected-name').value = '';
        }

        function viewFlow() {
            document.getElementById('viewFlowModal').classList.add('show');
        }

        function approveFlow(code) {
            var row = findApprovalRow(code, 'approval-pending-body');
            if (row) {
                document.getElementById('approveFlowCode').value = code;
                document.getElementById('approveCodeText').textContent = code;
                document.getElementById('approveNameText').textContent = row.cells[0].textContent;
            }
            document.getElementById('approveConfirmModal').classList.add('show');
        }

        function confirmApprove() {
            var code = document.getElementById('approveFlowCode').value;
            closeModal('approveConfirmModal');
            alert('已通过流程 ' + code + ' 的审批');
        }

        function rejectFlow(code) {
            var row = findApprovalRow(code, 'approval-pending-body');
            if (row) {
                document.getElementById('rejectFlowCode').value = code;
                document.getElementById('rejectCodeText').textContent = code;
                document.getElementById('rejectNameText').textContent = row.cells[0].textContent;
            }
            document.getElementById('rejectReason').value = '';
            document.getElementById('rejectModal').classList.add('show');
        }

        function confirmReject() {
            var code = document.getElementById('rejectFlowCode').value;
            var reason = document.getElementById('rejectReason').value;
            if (!reason) {
                alert('请输入拒绝原因');
                return;
            }
            closeModal('rejectModal');
            alert('已拒绝流程 ' + code + ' 的审批');
        }

        function findApprovalRow(code, bodyId) {
            var body = document.getElementById(bodyId);
            if (!body) return null;
            var rows = body.querySelectorAll('tr');
            for (var i = 0; i < rows.length; i++) {
                if (rows[i].cells[1].textContent === code) {
                    return rows[i];
                }
            }
            return null;
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('show');
        }

        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.classList.remove('show');
            }
        }
    </script>
</body>
</html>
